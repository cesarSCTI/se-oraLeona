<div class="container-fluid" style="background:{{ section.settings.bg }};padding:50px 0px" id="footer">

  <div class="container">
    <div class="row">
      <div class="col-md-6 col-sm-12 firstPart">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: height: 400 | image_tag: class: 'logo' }}
        {% endif %}
       <div class="customtext1">{{ section.settings.text1 }}</div>
       <div class="customtext2">{{ section.settings.text2 }}</div>
        <div class="areaFooterLinks">
      {% assign menu_handle = section.settings.menu2 %}
      {% if linklists[menu_handle] %}
        <ul>
          {% for link in linklists[menu_handle].links %}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p>No menu selected or menu is empty.</p>
      {% endif %}
    </div>
         {% if section.settings.logo2 != blank %}
          {{ section.settings.logo2 | image_url: width: 600 | image_tag: class: 'echo' }}
        {% endif %}
      </div>
      <div class="col-md-6 col-sm-12" style="text-align:center;">
        <h5>{{ section.settings.title }}</h5>
      </div>
    </div>
  </div>
</div>

{% comment %} ===== Barra inferior: todo centrado en una fila ===== {% endcomment %}
<div class="container-fluid bottom-line" style="background:{{ section.settings.bottom_bg }}; color:{{ section.settings.bottom_text_color }}; padding:20px 0px;">
  <div class="bottomBarInner">

    {% comment %} Logo Hecho en México {% endcomment %}
    {% if section.settings.mexico_logo != blank %}
      <div class="mexicoLogo">
        {{ section.settings.mexico_logo | image_url: width: 400 | image_tag: class: 'mexicoLogoImg', alt: 'Hecho en México' }}
      </div>
    {% endif %}

    {% comment %} Red social: icono + link personalizables. Si no subes icono, usa el snippet original {% endcomment %}
    {% if section.settings.social_icon != blank %}
      <a href="{{ section.settings.social_url }}" class="customSocial" target="_blank" rel="noopener" aria-label="{{ section.settings.social_label | default: 'Social media' }}">
        {{ section.settings.social_icon | image_url: width: 200 | image_tag: class: 'customSocialIcon' }}
      </a>
    {% else %}
      {% render 'footer-social', block: block, social_is_nested: true %}
    {% endif %}

    <div class="areaFooter">{{ section.settings.areaFooter }}</div>

    <div class="areaFooterLinks">
      {% assign menu_handle = section.settings.menu %}
      {% if linklists[menu_handle] %}
        <ul>
          {% for link in linklists[menu_handle].links %}
            <li>
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p>No menu selected or menu is empty.</p>
      {% endif %}
    </div>

  </div>
</div>

{% style %}
  .row{
    display:flex;
  }
  .col-md-4{
    width:33.3%;
    display:flex;
    flex-direction:column;
    gap:20px;
    align-items:center;
  }
  .col-md-8{
    width:66.6%;
  }
  .col-12{
    width:100%;
  }
  .col-md-6{
    width:50%;
  }
  .firstPart{
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    gap:50px;
  }

  /* ===== Tamaños personalizables (escritorio) ===== */
  #footer .logo{
    height:{{ section.settings.logo_height }}px;
    width:auto;
  }
  #footer .echo{
    width:{{ section.settings.logo2_width }}px;
    height:auto;
    max-width:100%;
  }
  .customtext1 {
    font-size:{{ section.settings.text1_size }}px;
  }
  .customtext2 {
    font-size:{{ section.settings.text2_size }}px;
  }
  #footer h5{
    font-size:{{ section.settings.title_size }}px;
  }

  /* ===== Barra inferior centrada ===== */
  .bottomBarInner{
    display:flex;
    justify-content:center;
    align-items:center;
    flex-wrap:wrap;
    gap:{{ section.settings.bottom_gap }}px;
    width:100%;
  }
  .mexicoLogo{
    display:flex;
    align-items:center;
  }
  .mexicoLogoImg{
    width:{{ section.settings.mexico_logo_width }}px;
    height:auto;
    display:block;
  }
  .customSocial{
    display:flex;
    align-items:center;
  }
  .customSocialIcon{
    width:{{ section.settings.social_icon_size }}px;
    height:{{ section.settings.social_icon_size }}px;
    object-fit:contain;
    display:block;
  }

  .areaFooter{
    font-family: 'Roboto Mono';
    text-transform:uppercase;
    padding:0px;
    font-weight:600;
  }
  .areaFooterLinks ul {
    display: flex;
    gap: 20px;
    padding: 0px;
    margin: 0px;
    margin-left:20px;
  }
  .areaFooterLinks li {
    list-style:none;
    font-family: 'Roboto Mono';
    text-transform:uppercase;
    font-weight:600;
  }
  .bottom-line .areaFooterLinks a{
    color:{{ section.settings.bottom_text_color }};
    text-decoration:none;
  }
  #footer a.link.link--text.list-social__link {
    background: #000;
  }
  #footer svg.icon {
    fill: #fff !important;
  }
  .bottom-line .list-social__link{
    background:transparent !important;
    color: #fff !important;
  }
  .list-social__item{
    margin:0px !important;
  }
  .emailContact {
    display: flex;
    justify-content: flex-end;
    font-size: larger;
  }

  /* ===== Móvil ===== */
  @media only screen and (max-width:768px){
    .col-sm-12{
      width:100%;
    }
    .areaFooterLinks ul{
      flex-direction:column;
      text-align:center;
      margin-left:0px;
    }
    .bottomBarInner{
      flex-direction:column;
      gap:{{ section.settings.bottom_gap_mobile }}px;
      text-align:center;
    }
    /* Tamaños específicos para móvil */
    #footer .logo{
      height:{{ section.settings.logo_height_mobile }}px;
    }
    #footer .echo{
      width:{{ section.settings.logo2_width_mobile }}px;
    }
    #footer h5{
      font-size:{{ section.settings.title_size_mobile }}px;
    }
    .customtext1{
      font-size:{{ section.settings.text1_size_mobile }}px;
    }
    .customtext2{
      font-size:{{ section.settings.text2_size_mobile }}px;
    }
    .mexicoLogoImg{
      width:{{ section.settings.mexico_logo_width_mobile }}px;
    }
    .customSocialIcon{
      width:{{ section.settings.social_icon_size_mobile }}px;
      height:{{ section.settings.social_icon_size_mobile }}px;
    }
  }
{% endstyle %}

